rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (UID)
    // Fields:
    //   - uid: string (required) - The unique identifier for the user.
    //   - email: string (required) - The user's email address.
    //   - displayName: string (optional) - The user's display name.
    //   - photoURL: string (optional) - The user's profile picture URL.
    //   - balance: number (required) - The current account balance.
    //   - pin: string (optional) - The user's 4-digit PIN.
    //   - createdAt: timestamp (required) - When the user account was created.
    //
    // Collection: transactions
    // Document ID: transactionId
    // Fields:
    //   - userId: string (required) - The ID of the user who owns this transaction.
    //   - amount: number (required) - The transaction amount.
    //   - type: string (required) - "credit" or "debit".
    //   - description: string (required) - A description of the transaction.
    //   - timestamp: timestamp (required) - When the transaction occurred.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "homlergarten@gmail.com" && request.auth.token.email_verified == true));
    }
    
    function isValidEmail(email) {
      return email is string && email.size() > 3 && email.size() < 100;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'email', 'displayName', 'photoURL', 'balance', 'points', 'creditScore', 'pin', 'createdAt', 'role']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.balance is number &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() < 500)) &&
             (!('points' in data) || data.points is number) &&
             (!('creditScore' in data) || data.creditScore is number) &&
             (!('pin' in data) || data.pin == null || (data.pin is string && data.pin.size() == 4)) &&
             (!('role' in data) || data.role is string) &&
             data.createdAt is timestamp;
    }

    function isValidTransaction(data) {
      return hasOnlyAllowedFields(['userId', 'amount', 'type', 'description', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.amount is number && data.amount > 0 &&
             data.type in ['credit', 'debit'] &&
             data.description is string && data.description.size() <= 100 &&
             data.timestamp is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                      (request.resource.data.get('role', 'client') == 'client' || isAdmin());
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data) && 
                      request.resource.data.uid == resource.data.uid &&
                      request.resource.data.createdAt == resource.data.createdAt &&
                      (request.resource.data.get('role', 'client') == resource.data.get('role', 'client') || isAdmin());
      
      match /transactions/{transactionId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidTransaction(request.resource.data);
      }
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
